# Copy this file to .env and fill in the real values.

CHRIS_DATABASE_URL=postgresql://username:password@host/database?sslmode=require
PARTNER_DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Use House A when Chris runs the server.
# Use House B when Matthew runs the server.
LOCAL_HOUSE=House A

# UTC time when DataNiz sharing was enabled.
# Example format: 2026-04-30T00:00:00+00:00
SHARING_START_UTC=2026-04-30T00:00:00+00:00
